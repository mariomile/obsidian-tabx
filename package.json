{
  "name": "tabx",
  "version": "0.1.0",
  "description": "See your open tabs as a vertical rail and a Masonry-style grid.",
  "main": "main.js",
  "type": "module",
  "packageManager": "pnpm@10.17.1",
  "scripts": {
    "dev": "node esbuild.config.mjs",
    "build": "pnpm typecheck && node esbuild.config.mjs production",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src",
    "test": "node --experimental-strip-types --test src/*.test.ts"
  },
  "keywords": [
    "obsidian",
    "tabs",
    "sidebar",
    "workspace"
  ],
  "author": "Mario Miletta",
  "license": "MIT",
  "engines": {
    "node": ">=22"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/node": "^22.15.17",
    "esbuild": "0.25.5",
    "eslint": "^9.39.4",
    "eslint-plugin-obsidianmd": "^0.4.0",
    "globals": "^17.6.0",
    "jiti": "^2.6.1",
    "obsidian": "1.13.1",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.59.1"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  }
}
